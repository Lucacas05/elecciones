---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileNav from '../components/MobileNav.astro';
import CandidateProfileCard from '../components/CandidateProfileCard.astro';
import { getCollection } from 'astro:content';

const allCandidatos = await getCollection('candidatos');
const candidatos = allCandidatos
  .map((entry) => entry.data)
  .sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));
---

<Layout title="Candidatos · Decide Perú">
  <Navbar currentPage="candidatos" />

  <main class="min-h-screen pt-28 pb-20 bg-background">
    <section>
      <div class="mx-auto max-w-6xl px-6 lg:px-12">
        <div class="grid gap-8">
          {candidatos.map((candidate, index) => <CandidateProfileCard candidate={candidate} index={index} />)}
        </div>
      </div>
    </section>
  </main>

  <MobileNav currentPage="candidatos" />
</Layout>
