---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileNav from '../components/MobileNav.astro';
import QuestionnaireSection from '../components/QuestionnaireSection.astro';
import ResultsSection from '../components/ResultsSection.astro';
import RankingSection from '../components/RankingSection.astro';
import BreakdownSection from '../components/BreakdownSection.astro';
import { getCollection } from 'astro:content';

const allCandidatos = await getCollection('candidatos');
const candidatosData = allCandidatos.map((c) => c.data);
---

<Layout title="Decide Perú · Cuestionario">
  <Navbar currentPage="cuestionario" />

  <main class="min-h-screen pb-24 md:pb-0">
    <section class="pt-28 pb-6">
      <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6 lg:px-12">
        <div class="inline-flex w-fit items-center gap-2 rounded-[2rem] bg-secondary-container px-4 py-1.5 text-sm font-semibold tracking-wide text-on-secondary-container">
          <span class="material-symbols-outlined text-sm">quiz</span>
          TEST DE AFINIDAD ELECTORAL
        </div>

        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div class="space-y-5">
            <h1 class="max-w-4xl font-headline text-5xl font-extrabold leading-[1.05] tracking-tight text-primary lg:text-7xl">
              Haz el test y descubre tu afinidad política
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-on-surface-variant">
              Responde el cuestionario completo y revisa en qué ejes coincides más
              con cada candidatura y cuáles pesan más en el resultado.
            </p>
          </div>

          <div class="rounded-[1.75rem] border border-outline-variant/10 bg-surface-container-lowest p-6 shadow-[0_4px_40px_rgba(0,27,68,0.04)] md:p-8">
            <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-primary/60">
              Antes de empezar
            </p>
            <div class="mt-6 space-y-5">
              <div class="flex items-start gap-4">
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-secondary-container text-on-secondary-container">
                  <span class="material-symbols-outlined text-base">visibility</span>
                </div>
                <p class="text-sm leading-6 text-on-surface-variant">
                  Tus respuestas se guardan solo en tu navegador para que puedas retomar el test.
                </p>
              </div>
              <div class="flex items-start gap-4">
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-secondary-container text-on-secondary-container">
                  <span class="material-symbols-outlined text-base">leaderboard</span>
                </div>
                <p class="text-sm leading-6 text-on-surface-variant">
                  Al completar todas las respuestas verás tu coincidencia principal, el ranking completo y el detalle por tema.
                </p>
              </div>
              <div class="flex items-start gap-4">
                <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-secondary-container text-on-secondary-container">
                  <span class="material-symbols-outlined text-base">groups</span>
                </div>
                <p class="text-sm leading-6 text-on-surface-variant">
                  Si quieres más contexto antes de responder, revisa primero la página de candidatos.
                </p>
              </div>
            </div>
            <a
              href="/candidatos"
              class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-primary"
            >
              <span class="underline decoration-primary/30 underline-offset-4">Ver perfiles de candidatura</span>
              <span class="material-symbols-outlined text-base no-underline">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <QuestionnaireSection />
    <ResultsSection />
    <RankingSection />
    <BreakdownSection />
  </main>

  <MobileNav currentPage="cuestionario" />

  <script define:vars={{ candidatosData }}>
    window.__CANDIDATOS_DATA__ = candidatosData;
  </script>
  <script type="module" src="/script.js" is:inline></script>
</Layout>
