---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileNav from '../components/MobileNav.astro';
import SurveyTimelinesSection from '../components/SurveyTimelinesSection.astro';
---

<Layout title="Decide Perú · Encuestas">
  <Navbar currentPage="encuestas" />

  <main class="min-h-screen pt-20 pb-24 md:pb-0">
    <section class="pt-8 pb-2">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <h1 class="px-2 font-headline text-4xl font-extrabold tracking-tight text-primary lg:text-5xl">
          Encuestas
        </h1>
      </div>
    </section>

    <SurveyTimelinesSection />
  </main>

  <MobileNav currentPage="encuestas" />

  <script type="module" src="/script.js" is:inline></script>
</Layout>
