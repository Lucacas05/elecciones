---
import { getPlanPdfHref } from '../lib/planLinks';

interface CandidateData {
  nombre: string;
  partido: string;
  logo_partido: string;
  foto: string;
  edad: number;
  profesion: string;
  experiencia_politica: string;
  propuestas: string[];
  dato_clave: string;
  partido_ideologia: string;
  plan_gobierno_url: string;
  hoja_vida_url: string;
  quiz_posiciones: Record<string, string>;
}

interface Props {
  candidate: CandidateData;
  index: number;
}

const { candidate, index } = Astro.props;
const logoPathOverrides: Record<string, string | null> = {
  '/img/partidos/accion-popular.webp': '/img/partidos/accion-popular.png',
  '/img/partidos/ahora-nacion.webp': '/img/partidos/ahora-nacion.jpg',
  '/img/partidos/app.webp': '/img/partidos/app.png',
  '/img/partidos/avanza-pais.webp': '/img/partidos/avanza-pais.jpg',
  '/img/partidos/cooperacion-popular.webp': '/img/partidos/cooperacion-popular.png',
  '/img/partidos/fe-en-el-peru.webp': '/img/partidos/fe-en-el-peru.png',
  '/img/partidos/frente-de-la-esperanza.webp': '/img/partidos/frente-de-la-esperanza.png',
  '/img/partidos/fuerza-popular.webp': '/img/partidos/fuerza-popular.png',
  '/img/partidos/integridad-democratica.webp': '/img/partidos/integridad-democratica.jpg',
  '/img/partidos/juntos-por-el-peru.webp': '/img/partidos/juntos-por-el-peru.png',
  '/img/partidos/libertad-popular.webp': '/img/partidos/libertad-popular.jpg',
  '/img/partidos/obras.webp': '/img/partidos/obras.png',
  '/img/partidos/pais-para-todos.webp': '/img/partidos/pais-para-todos.jpg',
  '/img/partidos/partido-democrata-unido-peru.webp': '/img/partidos/partido-democrata-unido-peru.jpg',
  '/img/partidos/partido-democratico-federal.webp': '/img/partidos/partido-democratico-federal.jpg',
  '/img/partidos/partido-morado.webp': '/img/partidos/partido-morado.png',
  '/img/partidos/partido-patriotico-del-peru.webp': '/img/partidos/partido-patriotico-del-peru.png',
  '/img/partidos/pbg.webp': '/img/partidos/pbg.jpg',
  '/img/partidos/peru-libre.webp': '/img/partidos/peru-libre.png',
  '/img/partidos/peru-primero.webp': '/img/partidos/peru-primero.jpg',
  '/img/partidos/podemos-peru.webp': '/img/partidos/podemos-peru.png',
  '/img/partidos/prin.webp': '/img/partidos/prin.png',
  '/img/partidos/progresemos.webp': '/img/partidos/progresemos.jpg',
  '/img/partidos/pte.webp': '/img/partidos/pte.jpg',
  '/img/partidos/renovacion-popular.webp': '/img/partidos/renovacion-popular.png',
  '/img/partidos/salvemos-al-peru.webp': '/img/partidos/salvemos-al-peru.jpg',
  '/img/partidos/somos-peru.webp': '/img/partidos/somos-peru.png',
  '/img/partidos/venceremos.webp': '/img/partidos/venceremos.png',
  '/img/partidos/fuerza-y-libertad.webp': '/img/partidos/fuerza-y-libertad.svg',
  '/img/partidos/peru-accion.webp': '/img/partidos/peru-accion.svg',
  '/img/partidos/peru-moderno.webp': '/img/partidos/peru-moderno.svg',
  '/img/partidos/primero-la-gente.webp': '/img/partidos/primero-la-gente.svg',
  '/img/partidos/si-creo.webp': '/img/partidos/si-creo.svg',
  '/img/partidos/un-camino-diferente.webp': '/img/partidos/un-camino-diferente.svg',
  '/img/partidos/unidad-nacional.webp': '/img/partidos/unidad-nacional.svg',
};

const photoPath = candidate.foto?.trim() || '';
const logoPath = logoPathOverrides[candidate.logo_partido] ?? candidate.logo_partido;
const hasPhoto = Boolean(photoPath);
const hasLogo = Boolean(logoPath);

const planHref = getPlanPdfHref(candidate.partido);
const initials = candidate.nombre
  .split(' ')
  .map((word) => word[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();

const partyInitials = candidate.partido
  .split(' ')
  .map((word) => word[0])
  .join('')
  .slice(0, 3)
  .toUpperCase();

const topicDefinitions = [
  {
    key: 'seguridad',
    label: 'Seguridad',
    icon: 'gavel',
    values: {
      mano_dura: 'Mano dura y sanciones severas',
      reforma_institucional: 'Reforma policial y judicial',
      prevencion: 'Prevención y trabajo comunitario',
    },
  },
  {
    key: 'economia',
    label: 'Economía',
    icon: 'payments',
    values: {
      libre_mercado: 'Libre mercado y menor regulación',
      intervencion_estatal: 'Mayor intervención estatal',
      mixta: 'Equilibrio entre mercado y regulación',
    },
  },
  {
    key: 'educacion',
    label: 'Educación',
    icon: 'school',
    values: {
      publica_prioridad: 'Prioridad a la educación pública',
      privada_incentivo: 'Impulso a la educación privada',
      mixta: 'Mejora combinada del sistema',
    },
  },
  {
    key: 'salud',
    label: 'Salud',
    icon: 'health_and_safety',
    values: {
      sistema_universal: 'Sistema universal',
      privado_complementario: 'Privado como complemento',
      mixto: 'Integración del sistema mixto',
    },
  },
  {
    key: 'corrupcion',
    label: 'Corrupción',
    icon: 'policy',
    values: {
      pena_muerte: 'Pena máxima como respuesta',
      cadena_perpetua: 'Cadena perpetua e inhabilitación',
      reforma_judicial: 'Reforma judicial y fiscal',
    },
  },
  {
    key: 'mineria',
    label: 'Minería',
    icon: 'landscape',
    values: {
      pro_mineria: 'Promoción de inversión minera',
      regulacion_estricta: 'Regulación ambiental estricta',
      consulta_previa: 'Consulta previa obligatoria',
    },
  },
  {
    key: 'descentralizacion',
    label: 'Descentralización',
    icon: 'location_city',
    values: {
      mas_poder_regiones: 'Más poder para regiones',
      gobierno_central: 'Mayor control desde Lima',
      gradual: 'Transferencia gradual con asistencia',
    },
  },
  {
    key: 'politica_social',
    label: 'Política social',
    icon: 'diversity_3',
    values: {
      bonos_directos: 'Bonos y transferencias directas',
      programas_empleo: 'Programas públicos de empleo',
      educacion_tecnica: 'Formación técnica y empleo',
    },
  },
  {
    key: 'instituciones',
    label: 'Instituciones',
    icon: 'account_balance',
    values: {
      autoridad_ejecutiva: 'Ejecutivo fuerte y orden',
      reforma_estado: 'Reforma del Estado y gestión',
      transparencia_control: 'Controles y transparencia',
    },
  },
  {
    key: 'empleo_formalizacion',
    label: 'Empleo',
    icon: 'work',
    values: {
      inversion_privada: 'Inversión privada y menos trabas',
      empleo_publico: 'Obras y empleo desde el Estado',
      capacitacion_formalizacion: 'Capacitación y formalización',
    },
  },
];

const topicEntries = topicDefinitions.map((topic) => ({
  ...topic,
  value:
    topic.values[candidate.quiz_posiciones[topic.key] as keyof typeof topic.values] ??
    'Posición no definida',
}));
---

<article class="space-y-6">
  <div class="institutional-gradient relative overflow-hidden rounded-[2rem] p-7 md:p-10 shadow-[0_20px_60px_rgba(0,27,68,0.16)]">
    <div class="absolute top-[-64px] right-[-36px] h-56 w-56 rounded-full bg-white/5"></div>
    <div class="absolute bottom-[-92px] left-[-32px] h-44 w-44 rounded-full bg-white/5"></div>

    <div class="relative z-10 grid gap-8 xl:grid-cols-[1.2fr_0.8fr] xl:items-start">
      <div class="space-y-5">
        <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.22em] text-white/80">
          <span class="material-symbols-outlined text-sm">verified</span>
          Candidatura {String(index + 1).padStart(2, '0')}
        </div>

        <div class="flex flex-wrap items-center gap-4">
          <div class="flex h-16 w-16 items-center justify-center overflow-hidden rounded-2xl border border-white/20 bg-white">
            {hasLogo ? (
              <img
                src={logoPath}
                alt={`Logo de ${candidate.partido}`}
                class="h-full w-full object-contain p-1"
                loading="lazy"
              />
            ) : (
              <span class="font-headline text-lg font-extrabold tracking-[0.18em] text-primary/70">
                {partyInitials}
              </span>
            )}
          </div>

          <div class="space-y-1">
            <h2 class="font-headline text-3xl font-extrabold tracking-tight text-white md:text-4xl">
              {candidate.nombre}
            </h2>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-white/80">
              {candidate.partido}
            </p>
          </div>
        </div>

        <p class="max-w-3xl text-sm leading-7 text-white/90 md:text-base">
          {candidate.profesion} · {candidate.experiencia_politica}
        </p>

        <div class="flex flex-wrap gap-2">
          <span class="rounded-full bg-white/10 px-3 py-2 text-xs font-bold uppercase tracking-[0.18em] text-white">
            {candidate.edad} años
          </span>
        </div>
      </div>

      <div class="rounded-[1.75rem] border border-white/12 bg-white/8 p-5 backdrop-blur-sm md:p-6">
        <div class="flex items-start gap-4">
          <div class="flex h-24 w-24 shrink-0 items-center justify-center overflow-hidden rounded-[1.5rem] border border-white/14 bg-white/10">
            {hasPhoto ? (
              <img
                src={photoPath}
                alt={candidate.nombre}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            ) : (
              <span class="font-headline text-3xl font-extrabold tracking-[0.08em] text-white/82">
                {initials}
              </span>
            )}
          </div>

          <div class="space-y-2">
            <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/70">
              Dato clave
            </p>
            <p class="text-sm leading-6 text-white/90">
              {candidate.dato_clave}
            </p>
          </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl bg-white/10 px-4 py-3">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-white/70">Profesión</p>
            <p class="mt-1 text-sm font-semibold text-white">{candidate.profesion}</p>
          </div>
          <div class="rounded-2xl bg-white/10 px-4 py-3">
            <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-white/70">Partido</p>
            <p class="mt-1 text-sm font-semibold text-white">{candidate.partido}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="rounded-[1.75rem] border border-outline-variant/10 bg-surface-container-lowest p-6 shadow-[0_4px_40px_rgba(0,27,68,0.04)] md:p-8">
      <div class="mb-6 flex items-center gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-secondary-container text-on-secondary-container">
          <span class="material-symbols-outlined">format_list_bulleted</span>
        </div>
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-primary/60">Lectura rápida</p>
          <h3 class="font-headline text-2xl font-extrabold text-primary">Propuestas destacadas</h3>
        </div>
      </div>

      <ul class="space-y-4">
        {candidate.propuestas.map((propuesta) => (
          <li class="flex gap-3 rounded-2xl bg-surface-container-low px-4 py-4 text-sm leading-6 text-on-surface-variant">
            <span class="mt-0.5 text-primary">→</span>
            <span>{propuesta}</span>
          </li>
        ))}
      </ul>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={planHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-3 text-sm font-bold text-on-primary transition-all hover:bg-primary-container"
        >
          <span class="material-symbols-outlined text-lg">description</span>
          Ver plan de gobierno
        </a>
      </div>
    </section>

    <section class="rounded-[1.75rem] border border-outline-variant/10 bg-surface-container-low p-6 shadow-[0_4px_40px_rgba(0,27,68,0.04)] md:p-8">
      <div class="mb-6 flex items-center gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white text-primary">
          <span class="material-symbols-outlined">hub</span>
        </div>
        <div>
          <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-primary/60">Perfil programático</p>
          <h3 class="font-headline text-2xl font-extrabold text-primary">Posiciones por tema</h3>
        </div>
      </div>

      <div class="grid gap-3 md:grid-cols-2">
        {topicEntries.map((topic) => (
          <div class="rounded-2xl border border-outline-variant/10 bg-white/70 px-4 py-4">
            <div class="mb-2 flex items-center gap-2">
              <span class="material-symbols-outlined text-base text-primary">{topic.icon}</span>
              <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-primary/70">
                {topic.label}
              </p>
            </div>
            <p class="text-sm leading-6 text-on-surface-variant">
              {topic.value}
            </p>
          </div>
        ))}
      </div>

      <div class="mt-6 rounded-[1.5rem] border border-dashed border-outline-variant/25 bg-white/50 px-4 py-4">
        <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-primary/60">
          Siguiente paso
        </p>
        <p class="mt-2 text-sm leading-6 text-on-surface-variant">
          Si quieres ver qué tan cerca estás de este perfil, vuelve al cuestionario y compara tus respuestas.
        </p>
        <a
          href="/cuestionario"
          class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-primary underline decoration-primary/30 underline-offset-4"
        >
          <span class="material-symbols-outlined text-lg">compare_arrows</span>
          Comparar con mis respuestas
        </a>
      </div>
    </section>
  </div>
</article>
