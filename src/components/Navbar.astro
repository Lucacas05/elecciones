---
const navLinks = [
  { href: '#inicio', label: 'Inicio', icon: 'home' },
  { href: '#cuestionario', label: 'Cuestionario', icon: 'quiz' },
  { href: '#comparativa', label: 'Comparativa', icon: 'compare_arrows' },
  { href: '#resultados', label: 'Resultados', icon: 'analytics' },
  { href: '#metodologia', label: 'Metodología', icon: 'library_books' },
];
---

<nav
  class="flex justify-between items-center w-full px-6 md:px-8 py-4 bg-surface/80 backdrop-blur-2xl border-b border-surface-container/50 fixed top-0 z-[60] font-headline tracking-tight"
>
  <div class="text-xl font-bold text-primary uppercase tracking-wider">
    Decide Perú
  </div>

  <div class="hidden md:flex items-center gap-1">
    {navLinks.map((link) => (
      <a
        class="nav-link flex items-center gap-2 px-4 py-2 text-on-surface-variant hover:text-primary hover:bg-primary/5 rounded-lg transition-all text-sm font-semibold"
        href={link.href}
        data-section={link.href.replace('#', '')}
      >
        <span class="material-symbols-outlined text-lg">{link.icon}</span>
        {link.label}
      </a>
    ))}
  </div>

  <div class="flex items-center gap-3">
    <button
      class="flex items-center gap-2 px-4 py-2 rounded-lg bg-primary/5 text-primary hover:bg-primary/10 transition-colors font-semibold text-sm"
      type="button"
      id="nav-results-btn"
    >
      <span class="material-symbols-outlined text-xl">analytics</span>
      <span class="hidden sm:inline">Ver resultados</span>
    </button>
  </div>
</nav>

<script>
  const navResultsBtn = document.getElementById('nav-results-btn');
  navResultsBtn?.addEventListener('click', () => {
    document.getElementById('resultados')?.scrollIntoView({ behavior: 'smooth' });
  });

  const navLinks = document.querySelectorAll('.nav-link');
  const sections = document.querySelectorAll('section[id], header[id]');

  function updateActiveNav() {
    let current = '';
    sections.forEach((section) => {
      if (section.offsetParent === null && !section.closest('body')) return;
      if (section.classList.contains('hidden')) return;
      const rect = section.getBoundingClientRect();
      if (rect.top <= 120) {
        current = section.id;
      }
    });

    navLinks.forEach((link) => {
      const section = link.getAttribute('data-section');
      if (section === current) {
        link.classList.add('text-primary', 'bg-primary/5', 'font-bold');
        link.classList.remove('text-on-surface-variant');
      } else {
        link.classList.remove('text-primary', 'bg-primary/5', 'font-bold');
        link.classList.add('text-on-surface-variant');
      }
    });
  }

  window.addEventListener('scroll', updateActiveNav, { passive: true });
  updateActiveNav();
</script>
