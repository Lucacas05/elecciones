---
interface Props {
  currentPage?: 'home' | 'candidatos';
}

const { currentPage = 'home' } = Astro.props;
const homePrefix = currentPage === 'home' ? '' : '/';

const navLinks = [
  { href: `${homePrefix}#inicio`, label: 'Inicio', icon: 'home', section: 'inicio' },
  { href: `${homePrefix}#cuestionario`, label: 'Cuestionario', icon: 'quiz', section: 'cuestionario' },
  { href: `${homePrefix}#resultados`, label: 'Resultados', icon: 'analytics', section: 'resultados' },
  { href: '/candidatos', label: 'Candidatos', icon: 'groups', section: 'candidatos' },
];
---

<nav
  class="flex justify-between items-center w-full px-6 md:px-8 py-4 bg-surface/80 backdrop-blur-2xl border-b border-surface-container/50 fixed top-0 z-[60] font-headline tracking-tight"
>
  <div class="text-xl font-bold text-primary uppercase tracking-wider">
    Decide Perú
  </div>

  <div class="hidden md:flex items-center gap-1">
    {navLinks.map((link) => (
      <a
        class:list={[
          'nav-link flex items-center gap-2 px-4 py-2 rounded-lg transition-all text-sm font-semibold',
          currentPage === 'candidatos' && link.section === 'candidatos'
            ? 'text-primary bg-primary/5 font-bold'
            : 'text-on-surface-variant hover:text-primary hover:bg-primary/5',
        ]}
        href={link.href}
        data-section={link.section}
      >
        <span class="material-symbols-outlined text-lg">{link.icon}</span>
        {link.label}
      </a>
    ))}
  </div>

  <div class="flex items-center gap-3">
    <a
      class="flex items-center gap-2 px-4 py-2 rounded-lg bg-primary/5 text-primary hover:bg-primary/10 transition-colors font-semibold text-sm"
      href={currentPage === 'home' ? '#resultados' : '/#cuestionario'}
      id="nav-results-btn"
    >
      <span class="material-symbols-outlined text-xl">
        {currentPage === 'home' ? 'monitoring' : 'quiz'}
      </span>
      <span class="hidden sm:inline">
        {currentPage === 'home' ? 'Mercado en vivo' : 'Hacer el test'}
      </span>
    </a>
  </div>
</nav>

{currentPage === 'home' && (
  <script>
    const navResultsBtn = document.getElementById('nav-results-btn');
    navResultsBtn?.addEventListener('click', (event) => {
      const href = navResultsBtn.getAttribute('href');
      if (href !== '#resultados') return;
      event.preventDefault();
      document.getElementById('resultados')?.scrollIntoView({ behavior: 'smooth' });
    });

    const navLinks = document.querySelectorAll('.nav-link');
    const sections = document.querySelectorAll('section[id], header[id]');

    function updateActiveNav() {
      let current = '';
      sections.forEach((section) => {
        if (section.offsetParent === null && !section.closest('body')) return;
        if (section.classList.contains('hidden')) return;
        const rect = section.getBoundingClientRect();
        if (rect.top <= 120) {
          current = section.id;
        }
      });

      navLinks.forEach((link) => {
        const section = link.getAttribute('data-section');
        if (section === 'candidatos') return;
        if (section === current) {
          link.classList.add('text-primary', 'bg-primary/5', 'font-bold');
          link.classList.remove('text-on-surface-variant');
        } else {
          link.classList.remove('text-primary', 'bg-primary/5', 'font-bold');
          link.classList.add('text-on-surface-variant');
        }
      });
    }

    window.addEventListener('scroll', updateActiveNav, { passive: true });
    updateActiveNav();
  </script>
)}
