---
interface Props {
  currentPage?: 'home' | 'candidatos';
}

const { currentPage = 'home' } = Astro.props;
const homePrefix = currentPage === 'home' ? '' : '/';
const shareUrl = homePrefix || '/';
const shareTitle = 'Decide Perú · Cuestionario electoral';
const shareText = 'Comparte este test de Decide Perú para ver qué candidatura se alinea más contigo.';

const navLinks = [
  { href: `${homePrefix}#inicio`, label: 'Inicio', icon: 'home', section: 'inicio' },
  { href: `${homePrefix}#cuestionario`, label: 'Cuestionario', icon: 'quiz', section: 'cuestionario' },
  { href: `${homePrefix}#resultados`, label: 'Resultados', icon: 'analytics', section: 'resultados' },
  { href: '/candidatos', label: 'Candidatos', icon: 'groups', section: 'candidatos' },
];
---

<nav
  class="flex justify-between items-center w-full px-6 md:px-8 py-4 bg-surface/80 backdrop-blur-2xl border-b border-surface-container/50 fixed top-0 z-[60] font-headline tracking-tight"
>
  <div class="text-xl font-bold text-primary uppercase tracking-wider">
    Decide Perú
  </div>

  <div class="hidden md:flex items-center gap-1">
    {navLinks.map((link) => (
      <a
        class:list={[
          'nav-link flex items-center gap-2 px-4 py-2 rounded-lg transition-all text-sm font-semibold',
          currentPage === 'candidatos' && link.section === 'candidatos'
            ? 'text-primary bg-primary/5 font-bold'
            : 'text-on-surface-variant hover:text-primary hover:bg-primary/5',
        ]}
        href={link.href}
        data-section={link.section}
      >
        <span class="material-symbols-outlined text-lg">{link.icon}</span>
        {link.label}
      </a>
    ))}
  </div>

  <div class="flex items-center gap-3">
    <button
      class="flex items-center gap-2 px-4 py-2 rounded-lg bg-primary/5 text-primary hover:bg-primary/10 transition-colors font-semibold text-sm"
      type="button"
      id="nav-share-btn"
      data-share-url={shareUrl}
      data-share-title={shareTitle}
      data-share-text={shareText}
      data-home-page={currentPage === 'home' ? 'true' : 'false'}
      aria-label="Compartir Decide Perú"
    >
      <span class="material-symbols-outlined text-xl">share</span>
      <span class="hidden sm:inline">Compartir</span>
    </button>
  </div>
</nav>

<script>
  const navShareBtn = document.getElementById('nav-share-btn');

  async function handleShare() {
    if (!navShareBtn) return;

    const shareUrl = navShareBtn.getAttribute('data-share-url') || '/';
    const shareTitle = navShareBtn.getAttribute('data-share-title') || document.title;
    const shareText = navShareBtn.getAttribute('data-share-text') || '';
    const absoluteUrl = new URL(shareUrl, window.location.origin).toString();
    const sharePayload = {
      title: shareTitle,
      text: shareText,
      url: absoluteUrl,
    };

    try {
      if (navigator.share) {
        await navigator.share(sharePayload);
        return;
      }

      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(absoluteUrl);
        window.alert('Enlace copiado para compartir el test.');
        return;
      }

      window.prompt('Copia este enlace para compartir el test:', absoluteUrl);
    } catch (error) {
      if (error instanceof DOMException && error.name === 'AbortError') {
        return;
      }

      console.error('No se pudo compartir el enlace del test.', error);
      window.prompt('Copia este enlace para compartir el test:', absoluteUrl);
    }
  }

  navShareBtn?.addEventListener('click', handleShare);

  const isHomePage = navShareBtn?.getAttribute('data-home-page') === 'true';

  if (isHomePage) {
    const navLinks = document.querySelectorAll('.nav-link');
    const sections = document.querySelectorAll('section[id], header[id]');

    function updateActiveNav() {
      let current = '';
      sections.forEach((section) => {
        if (section.offsetParent === null && !section.closest('body')) return;
        if (section.classList.contains('hidden')) return;
        const rect = section.getBoundingClientRect();
        if (rect.top <= 120) {
          current = section.id;
        }
      });

      navLinks.forEach((link) => {
        const section = link.getAttribute('data-section');
        if (section === 'candidatos') return;
        if (section === current) {
          link.classList.add('text-primary', 'bg-primary/5', 'font-bold');
          link.classList.remove('text-on-surface-variant');
        } else {
          link.classList.remove('text-primary', 'bg-primary/5', 'font-bold');
          link.classList.add('text-on-surface-variant');
        }
      });
    }

    window.addEventListener('scroll', updateActiveNav, { passive: true });
    updateActiveNav();
  }
</script>
