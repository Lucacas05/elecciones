---
interface Props {
  currentPage?: 'home' | 'cuestionario' | 'predicciones' | 'encuestas' | 'candidatos';
}

const { currentPage = 'home' } = Astro.props;
const pageMeta = {
  home: {
    shareUrl: '/',
    shareTitle: 'Decide Perú · Inicio',
    shareText: 'Explora Decide Perú, haz el test electoral y revisa a los candidatos.',
  },
  cuestionario: {
    shareUrl: '/cuestionario',
    shareTitle: 'Decide Perú · Cuestionario',
    shareText: 'Haz el test de Decide Perú y descubre qué candidatura se alinea más contigo.',
  },
  predicciones: {
    shareUrl: '/predicciones',
    shareTitle: 'Decide Perú · Predicciones',
    shareText: 'Revisa las predicciones en vivo de Decide Perú con datos de Polymarket.',
  },
  encuestas: {
    shareUrl: '/encuestas',
    shareTitle: 'Decide Perú · Encuestas',
    shareText: 'Sigue la evolución de las encuestas presidenciales con datos de Ipsos Perú.',
  },
  candidatos: {
    shareUrl: '/candidatos',
    shareTitle: 'Decide Perú · Candidatos',
    shareText: 'Explora los perfiles y propuestas de cada candidatura en Decide Perú.',
  },
} satisfies Record<string, { shareUrl: string; shareTitle: string; shareText: string }>;

const { shareUrl, shareTitle, shareText } = pageMeta[currentPage];

const navLinks = [
  { href: '/', label: 'Inicio', icon: 'home', page: 'home' },
  { href: '/cuestionario', label: 'Cuestionario', icon: 'quiz', page: 'cuestionario' },
  { href: '/encuestas', label: 'Encuestas', icon: 'timeline', page: 'encuestas' },
  { href: '/predicciones', label: 'Predicciones', icon: 'analytics', page: 'predicciones' },
  { href: '/candidatos', label: 'Candidatos', icon: 'groups', page: 'candidatos' },
];
---

<nav
  class="flex justify-between items-center w-full px-6 md:px-8 py-4 bg-background backdrop-blur-2xl fixed top-0 z-[60] font-headline tracking-tight"
>
  <div class="text-xl font-bold text-primary uppercase tracking-wider">
    Decide Perú
  </div>

  <div class="hidden md:flex items-center gap-1">
    {navLinks.map((link) => (
      <a
        class:list={[
          'nav-link flex items-center gap-2 px-4 py-2 rounded-lg transition-all text-sm font-semibold',
          currentPage === link.page
            ? 'text-primary bg-primary/5 font-bold'
            : 'text-on-surface-variant hover:text-primary hover:bg-primary/5',
        ]}
        href={link.href}
      >
        <span class="material-symbols-outlined text-lg">{link.icon}</span>
        {link.label}
      </a>
    ))}
  </div>

  <div class="flex items-center gap-3">
    <a
      href="https://github.com/lucasfbr/elecciones"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center p-2 rounded-lg text-on-surface-variant hover:text-primary hover:bg-primary/5 transition-colors"
      aria-label="Ver código fuente en GitHub"
    >
      <svg
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
        />
      </svg>
    </a>

    <button
      class="flex items-center gap-2 px-4 py-2 rounded-lg bg-primary/5 text-primary hover:bg-primary/10 transition-colors font-semibold text-sm"
      type="button"
      id="nav-share-btn"
      data-share-url={shareUrl}
      data-share-title={shareTitle}
      data-share-text={shareText}
      aria-label="Compartir Decide Perú"
    >
      <span class="material-symbols-outlined text-xl">share</span>
      <span class="hidden sm:inline">Compartir</span>
    </button>
  </div>
</nav>

<script>
  const navShareBtn = document.getElementById('nav-share-btn');

  async function handleShare() {
    if (!navShareBtn) return;

    const shareUrl = navShareBtn.getAttribute('data-share-url') || '/';
    const shareTitle = navShareBtn.getAttribute('data-share-title') || document.title;
    const shareText = navShareBtn.getAttribute('data-share-text') || '';
    const absoluteUrl = new URL(shareUrl, window.location.origin).toString();
    const sharePayload = {
      title: shareTitle,
      text: shareText,
      url: absoluteUrl,
    };

    try {
      if (navigator.share) {
        await navigator.share(sharePayload);
        return;
      }

      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(absoluteUrl);
        window.alert('Enlace copiado para compartir Decide Perú.');
        return;
      }

      window.prompt('Copia este enlace para compartir Decide Perú:', absoluteUrl);
    } catch (error) {
      if (error instanceof DOMException && error.name === 'AbortError') {
        return;
      }

      console.error('No se pudo compartir el enlace del test.', error);
      window.prompt('Copia este enlace para compartir Decide Perú:', absoluteUrl);
    }
  }

  navShareBtn?.addEventListener('click', handleShare);
</script>
