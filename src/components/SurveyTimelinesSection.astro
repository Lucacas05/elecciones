---
const charts = [
  {
    title: 'Timeline de encuestas 2026',
    description:
      'Serie interactiva de Ipsos Perú con la evolución de intención de voto para las elecciones generales de 2026.',
    src: '/graficos/encuestas-2026/index.html',
    linkLabel: 'Abrir gráfico 2026',
    heightClass: 'h-[920px] md:h-[980px]'
  },
  {
    title: 'Timeline de encuestas 2021',
    description:
      'Gráfico dinámico histórico de El Comercio / Ipsos con la evolución de las encuestas presidenciales de 2021.',
    src: '/graficos/encuestas-2021/index.html',
    linkLabel: 'Abrir gráfico 2021',
    heightClass: 'h-[900px] md:h-[960px]'
  }
];
---

<section class="py-8 md:py-12">
  <div class="mx-auto flex max-w-7xl flex-col gap-10 px-4 lg:px-8">
    {charts.map((chart) => (
      <div class="space-y-3">
        <div class="flex flex-col gap-3 px-2 sm:flex-row sm:items-center sm:justify-between">
          <h3 class="font-headline text-xl font-bold tracking-tight text-primary md:text-2xl">{chart.title}</h3>
          <a
            href={chart.src}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex shrink-0 items-center gap-2 rounded-lg text-sm font-semibold text-primary/60 transition-colors hover:text-primary"
          >
            <span class="material-symbols-outlined text-base">open_in_new</span>
            {chart.linkLabel}
          </a>
        </div>

        <iframe
          src={chart.src}
          title={chart.title}
          loading="lazy"
          class:list={['w-full bg-white', chart.heightClass]}
        ></iframe>
      </div>
    ))}
  </div>
</section>
