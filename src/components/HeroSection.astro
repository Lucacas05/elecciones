---
---

<header id="inicio" class="pt-36 md:pt-44 lg:pt-48 pb-16 md:pb-24 relative overflow-hidden">
  <!-- Floating decorative icons — well spaced, subtle -->
  <div class="absolute top-36 left-[5%] w-11 h-11 rounded-full border border-outline-variant/20 flex items-center justify-center text-on-surface-variant/25 hidden xl:flex">
    <span class="material-symbols-outlined text-xl">how_to_vote</span>
  </div>
  <div class="absolute top-[55%] left-[3%] w-9 h-9 rounded-full bg-secondary-container/25 flex items-center justify-center text-on-secondary-container/30 hidden xl:flex">
    <span class="material-symbols-outlined text-base">description</span>
  </div>
  <div class="absolute bottom-[18%] left-[7%] w-10 h-10 rounded-full border border-outline-variant/15 flex items-center justify-center text-on-surface-variant/20 hidden xl:flex">
    <span class="material-symbols-outlined text-lg">trending_up</span>
  </div>

  <div class="absolute top-36 right-[5%] w-11 h-11 rounded-full border border-outline-variant/20 flex items-center justify-center text-on-surface-variant/25 hidden xl:flex">
    <span class="material-symbols-outlined text-xl">bar_chart</span>
  </div>
  <div class="absolute top-[55%] right-[3%] w-9 h-9 rounded-full bg-secondary-container/25 flex items-center justify-center text-on-secondary-container/30 hidden xl:flex">
    <span class="material-symbols-outlined text-base">tune</span>
  </div>
  <div class="absolute bottom-[18%] right-[7%] w-10 h-10 rounded-full border border-outline-variant/15 flex items-center justify-center text-on-surface-variant/20 hidden xl:flex">
    <span class="material-symbols-outlined text-lg">shield_person</span>
  </div>

  <div class="max-w-6xl mx-auto px-6 lg:px-12">
    <!-- Centered headline -->
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-extrabold text-primary leading-[1.08] tracking-tight mb-6">
        Elige informado en las
        <span class="text-primary-container">Elecciones 2026</span>
      </h1>
      <p class="font-body text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10 md:mb-12">
        Compara candidatos, descubre tu afinidad política y toma una decisión con datos, no con ruido.
      </p>

      <!-- Two CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/cuestionario"
          class="px-8 py-4 bg-primary text-on-primary rounded-2xl font-headline font-bold text-lg hover:bg-primary-container transition-all active:scale-95 shadow-xl shadow-primary/10"
        >
          Realizar test
        </a>
        <a
          href="/candidatos"
          class="px-8 py-4 bg-surface-container-lowest text-primary border border-outline-variant rounded-2xl font-headline font-bold text-lg hover:bg-surface-container-high transition-all"
        >
          Candidatos
        </a>
      </div>
    </div>

    <!-- Stat cards row -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 mt-16 md:mt-20">
      <div class="bg-primary rounded-3xl p-7 md:p-8 text-on-primary flex flex-col relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300 shadow-lg shadow-primary/20">
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-white/10 rounded-full blur-2xl"></div>
        <span class="material-symbols-outlined text-on-primary/60 text-4xl mb-4 relative z-10">groups</span>
        <span class="font-headline text-5xl md:text-6xl font-extrabold relative z-10">36</span>
        <span class="text-on-primary/75 text-sm mt-3 leading-snug relative z-10">Candidatos presidenciales analizados</span>
      </div>

      <div class="bg-surface-container-lowest rounded-3xl p-7 md:p-8 border border-outline-variant/40 flex flex-col relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300 shadow-md shadow-on-surface/5">
        <div class="absolute top-0 right-0 w-20 h-20 bg-primary/5 rounded-full blur-xl"></div>
        <span class="material-symbols-outlined text-primary/50 text-4xl mb-4 relative z-10">quiz</span>
        <span class="font-headline text-5xl md:text-6xl font-extrabold text-primary relative z-10">16</span>
        <span class="text-on-surface-variant text-sm mt-3 relative z-10">Temas clave del debate</span>
      </div>

      <div class="bg-secondary-container/60 rounded-3xl p-7 md:p-8 flex flex-col relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300 backdrop-blur-sm border border-secondary-container/80 shadow-md shadow-on-surface/5">
        <div class="absolute -bottom-4 -left-4 w-28 h-28 bg-primary/10 rounded-full blur-2xl"></div>
        <span class="material-symbols-outlined text-primary/60 text-4xl mb-4 relative z-10">bolt</span>
        <span class="font-headline text-5xl md:text-6xl font-extrabold text-primary relative z-10">3 min</span>
        <span class="text-on-surface-variant text-sm mt-3 relative z-10">Tiempo estimado para completar</span>
      </div>

      <div class="bg-primary rounded-3xl p-7 md:p-8 text-on-primary flex flex-col relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300 shadow-lg shadow-primary/25">
        <div class="absolute -top-6 -left-6 w-32 h-32 bg-white/10 rounded-full blur-3xl"></div>
        <span class="material-symbols-outlined text-on-primary/60 text-4xl mb-4 relative z-10">verified</span>
        <span class="font-headline text-5xl md:text-6xl font-extrabold relative z-10">JNE</span>
        <span class="text-on-primary/75 text-sm mt-3 leading-snug relative z-10">Datos oficiales de planes de gobierno</span>
      </div>
    </div>
  </div>
</header>
