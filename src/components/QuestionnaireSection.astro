---
---

<section id="cuestionario" class="py-16 md:py-24">
  <div class="max-w-2xl mx-auto px-6 lg:px-8">
    <div class="quiz-shell">
      <div class="quiz-shell-header">
        <div class="flex items-center gap-3">
          <div class="quiz-icon-box">
            <span class="material-symbols-outlined text-primary" style="font-size:20px">quiz</span>
          </div>
          <span class="font-headline font-bold text-primary text-sm">10 temas clave</span>
        </div>
        <div class="text-right">
          <p class="text-[11px] uppercase tracking-[0.2em] text-on-surface-variant font-medium">Respuestas</p>
          <p id="answers-count" class="font-headline text-2xl font-extrabold text-primary tabular-nums">0/10</p>
        </div>
      </div>

      <div class="quiz-progress-panel">
        <div class="quiz-progress-copy">
          <p id="question-progress-label" class="quiz-progress-label">Pregunta 1 de 10</p>
          <p id="question-progress-helper" class="quiz-progress-helper">
            Elige una opción y pasarás automáticamente a la siguiente.
          </p>
        </div>
        <div class="progress-track progress-track--quiz" aria-hidden="true">
          <div id="quiz-progress-bar" class="progress-track__fill" style="width:10%"></div>
        </div>
      </div>

      <form id="questionnaire-form" class="quiz-form"></form>

      <div class="quiz-actions">
        <button
          id="previous-button"
          type="button"
          class="quiz-btn-secondary"
          disabled
          aria-disabled="true"
        >
          <span class="material-symbols-outlined text-lg">arrow_back</span>
          Anterior
        </button>
        <button
          id="submit-button"
          type="submit"
          form="questionnaire-form"
          class="quiz-btn-primary"
          disabled
          aria-disabled="true"
        >
          <span class="material-symbols-outlined text-lg">analytics</span>
          Ver resultados
        </button>
        <button
          id="reset-button"
          type="button"
          class="quiz-btn-secondary"
        >
          <span class="material-symbols-outlined text-lg">restart_alt</span>
          Reiniciar
        </button>
      </div>
    </div>
  </div>
</section>
