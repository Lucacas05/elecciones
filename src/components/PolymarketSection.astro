---
---

<section id="predicciones" class="py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-6 lg:px-12">
    <div class="rounded-[1.75rem] border border-outline-variant/10 bg-surface-container-lowest px-6 py-6 md:px-8 md:py-8">
      <div class="flex flex-col gap-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="space-y-2">
            <h2 class="font-headline text-2xl font-bold tracking-tight text-primary md:text-3xl">
              Ranking en vivo
            </h2>
          </div>

          <div class="flex flex-wrap items-center gap-2.5">
            <span id="polymarket-status" class="inline-flex items-center gap-2 rounded-full bg-surface px-3 py-2 text-xs font-bold uppercase tracking-[0.18em] text-primary">
              <span class="h-2 w-2 rounded-full bg-primary/40"></span>
              Cargando
            </span>
            <button
              id="polymarket-refresh"
              type="button"
              class="inline-flex items-center gap-2 rounded-xl border border-outline-variant/10 bg-surface px-4 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary/5"
            >
              <span class="material-symbols-outlined text-base">refresh</span>
              Actualizar
            </button>
            <a
              href="https://polymarket.com/es/event/peru-presidential-election-winner"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-xl border border-outline-variant/10 bg-surface px-4 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary/5"
            >
              <span class="material-symbols-outlined text-base">open_in_new</span>
              Abrir Polymarket
            </a>
          </div>
        </div>

        <div id="polymarket-board">
          <article class="rounded-[1.5rem] border border-outline-variant/10 bg-surface px-5 py-6 md:px-6">
            <div class="animate-pulse space-y-4">
              <div class="h-4 w-32 rounded-full bg-primary/10"></div>
              <div class="space-y-3">
                <div class="h-16 rounded-xl bg-primary/10"></div>
                <div class="h-16 rounded-xl bg-primary/10"></div>
                <div class="h-16 rounded-xl bg-primary/10"></div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
