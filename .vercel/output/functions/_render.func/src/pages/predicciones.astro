---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import MobileNav from '../components/MobileNav.astro';
import PolymarketSection from '../components/PolymarketSection.astro';
---

<Layout title="Decide Perú · Predicciones">
  <Navbar currentPage="predicciones" />

  <main class="min-h-screen pb-24 md:pb-0">
    <section class="pt-28 pb-6">
      <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6 lg:px-12">
        <div class="inline-flex w-fit items-center gap-2 rounded-[2rem] bg-secondary-container px-4 py-1.5 text-sm font-semibold tracking-wide text-on-secondary-container">
          <span class="material-symbols-outlined text-sm">query_stats</span>
          MERCADO PREDICTIVO
        </div>

        <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div class="space-y-5">
            <h1 class="max-w-4xl font-headline text-5xl font-extrabold leading-[1.05] tracking-tight text-primary lg:text-7xl">
              Sigue las predicciones del mercado en tiempo real
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-on-surface-variant">
              Aquí ves la señal del mercado predictivo de Polymarket para la presidencia de Perú,
              separada del test para que la navegación sea más clara.
            </p>
          </div>

          <div class="rounded-[1.75rem] border border-outline-variant/10 bg-surface-container-lowest p-6 shadow-[0_4px_40px_rgba(0,27,68,0.04)] md:p-8">
            <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-primary/60">
              Cómo leer esta página
            </p>
            <div class="mt-4 space-y-4">
              <div class="flex items-start gap-3">
                <div class="mt-1 flex h-8 w-8 items-center justify-center rounded-xl bg-secondary-container text-on-secondary-container">
                  <span class="material-symbols-outlined text-base">monitoring</span>
                </div>
                <p class="text-sm leading-6 text-on-surface-variant">
                  Los porcentajes reflejan precios implícitos del mercado, no intención de voto oficial.
                </p>
              </div>
              <div class="flex items-start gap-3">
                <div class="mt-1 flex h-8 w-8 items-center justify-center rounded-xl bg-secondary-container text-on-secondary-container">
                  <span class="material-symbols-outlined text-base">update</span>
                </div>
                <p class="text-sm leading-6 text-on-surface-variant">
                  La vista se actualiza automáticamente y también puedes refrescarla manualmente.
                </p>
              </div>
              <div class="flex items-start gap-3">
                <div class="mt-1 flex h-8 w-8 items-center justify-center rounded-xl bg-secondary-container text-on-secondary-container">
                  <span class="material-symbols-outlined text-base">open_in_new</span>
                </div>
                <p class="text-sm leading-6 text-on-surface-variant">
                  Si quieres más detalle, abre el mercado original desde el botón de Polymarket.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <PolymarketSection />
  </main>

  <MobileNav currentPage="predicciones" />

  <script src="/script.js" is:inline></script>
</Layout>
