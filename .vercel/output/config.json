{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/polymarket/peru-election\\.json/?$",
			"dest": "_render"
		},
		{
			"src": "^/candidatos/?$",
			"dest": "_render"
		},
		{
			"src": "^/cuestionario/?$",
			"dest": "_render"
		},
		{
			"src": "^/planes-de-gobierno/?$",
			"dest": "_render"
		},
		{
			"src": "^/predicciones/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}